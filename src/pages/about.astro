---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WindowPrompt from "../components/WindowPrompt.astro";
---

<BaseLayout title="Home">
  <div id="page">
    <Header />
    
    <div class="mainText">
      <h1>About Me.</h1>
      <p>Get to know me a little better.</p>
    </div>
    
    <WindowPrompt startTop={15} startLeft={5} title="Contact Me!">
      <div class="link-grid">
        <a href="mailto:tuffsany@gmail.com">୨ৎ Email</a>
        <a href="https://vsco.co/tuffsany/gallery">୨ৎ VSCO</a>
        <a href="https://www.instagram.com/tiff.visuals/">୨ৎ Instagram</a>
        <a href="https://www.instagram.com/tiffminrobotics/">୨ৎ Robotics Instagram</a>
        <a href="https://team24124.github.io/">୨ৎ Team 24124</a>
        <a href="https://github.com/tuffsany">୨ৎ Github</a>
      </div>
    </WindowPrompt>

    <WindowPrompt startTop={55} startLeft={8} title="Current Obsessions">
      <iframe
        style="border-radius:12px; display:block;"
        src="https://open.spotify.com/embed/playlist/2I5ATI31mh6vJuhyspnOC3"
        width="100%"
        height="352"
        frameBorder="0"
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"
      ></iframe>
    </WindowPrompt>

    <WindowPrompt startTop={20} startLeft={65} title="About Me">
      <div class="prompt-body has-image">
        <p>Hello! My name is Tiff.</p>
        <br>
        <p>I'm a designer, photographer, and developer based in Alberta, Canada.</p>
        <br>
        <p>Welcome to my internet lair.</p>
        <br>
        <p>Feel free to email or DM me if you have any questions or inquiries.</p>
        <img src="/images/about.jpg" class="prompt-image" draggable="false"/>
      </div>
    </WindowPrompt>
    
  </div>
  <Footer />
</BaseLayout>