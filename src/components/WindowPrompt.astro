---
const { startTop = 20, startLeft = 10, title = "Prompt" } = Astro.props;
---

<div 
  class="prompt"
  style={`top: ${startTop}vh; left: ${startLeft}vw;`}
>
  <div class="prompt-header">
    <span class="prompt-title">{title}</span>
  </div>

  <div class="prompt-body">
    <slot />
  </div>
</div>

<style is:global>
.prompt {
  user-select: none;
  width: 100%;
  max-height: none;
  max-width: min(500px, 90vw);
  color: #1d1d1d;
  position: absolute;
  cursor: default;
  filter: drop-shadow(2px 2px 4px #353535);
  overflow: hidden;
}

.prompt-header {
  height: 55px;
  background-image: url("/images/ui/prompt-header.png");
  background-size: cover;
  background-repeat: no-repeat;
  border-top-left-radius: 6px;
  border-top-right-radius: 6px;
  display: flex;
  align-items: center;
  padding: 0 12px;
  cursor: grab;
}

.prompt-header:active {
  cursor: grabbing;
}

.prompt-title {
  color: #6b6b6b;
  font-size: 12px;
  margin-left: 65px;
  margin-top: 25px;
}

.prompt-body {
  background-color: #f1f2f2;
  padding: 10px;
  border-bottom-left-radius: 6px;
  border-bottom-right-radius: 6px;
  line-height: 1.5;
  position: relative;
}

.prompt-body.has-image {
  padding-right: clamp(0px, 30vw, 317px);
}

.prompt-body p {
  text-align: left;
  font-size: 15px;
}

.prompt-image {
  position: absolute;
  right: 12px;
  top: 12px;
  width: clamp(150px, 30vw, 300px);
  height: auto;
  border-radius: 15px;
  user-select: none;
  pointer-events: none;
}

body.dragging {
  user-select: none;
}

@media (max-width: 768px) {
  .prompt {
    position: static;
    width: 100%;
    max-width: 100%;
    margin-bottom: 20px;
  }

  .prompt-image {
    position: relative;
    width: 100%;
    margin-top: 10px;
  }

  .prompt-body.has-image {
    padding-right: 10px;
  }
}
</style>

<script>
let highestZ = 1;

document.querySelectorAll('.prompt').forEach((prompt) => {
  const handle = prompt.querySelector('.prompt-header');

  let offsetX = 0;
  let offsetY = 0;
  let isDragging = false;

  handle.addEventListener("mousedown", (e) => {
    isDragging = true;

    const rect = prompt.getBoundingClientRect();
    offsetX = e.clientX - rect.left;
    offsetY = e.clientY - rect.top;

    highestZ++;
    prompt.style.zIndex = highestZ;

    document.body.classList.add("dragging");
  });

  document.addEventListener("mousemove", (e) => {
    if (!isDragging) return;

    let x = e.clientX - offsetX;
    let y = e.clientY - offsetY;

    // bounds
    const maxX = window.innerWidth - prompt.offsetWidth;
    const maxY = window.innerHeight - prompt.offsetHeight;

    x = Math.max(0, Math.min(x, maxX));
    y = Math.max(0, Math.min(y, maxY));

    const xVW = (x / window.innerWidth) * 100;
    const yVH = (y / window.innerHeight) * 100;

    prompt.style.left = `${xVW}vw`;
    prompt.style.top = `${yVH}vh`;
  });

  document.addEventListener("mouseup", () => {
    isDragging = false;
    document.body.classList.remove("dragging");
  });
});

</script>