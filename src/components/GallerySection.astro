---
interface Props {
  id: string;
  title: string;
  description: string;
  items: { src: string; alt: string; caption?: string; group: string }[];
}
const { id, title, description, items } = Astro.props;
---
<section class="gallery-section" id={id}>
  <h2 class="gallery-title">{title}</h2>
  <p class="gallery-description">{description}</p>
  <div class="photos">
    {items.map((item) => (
      <a href="#" class="photo" data-group={item.group}>
        <img src={item.src} alt={item.alt} />
        {item.caption && <div class="caption">{item.caption}</div>}
      </a>
    ))}
  </div>
</section>
